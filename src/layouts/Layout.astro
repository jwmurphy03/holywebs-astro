---
import '../styles/global.css';
import Navbar from '../components/Navbar';
import Footer from '../components/Footer';
import ExitIntentPopup from '../components/ExitIntentPopup';
import {
  DEFAULT_OG_IMAGE,
  SITE_NAME,
  absoluteUrl,
  breadcrumbSchema,
  cleanCanonical,
  getRobotsForPath,
  graphSchema,
  organizationSchema,
  serviceSchema,
  webpageSchema,
  websiteSchema,
} from '../lib/seo';

interface Props {
  title: string;
  description?: string;
  ogImage?: string;
  canonicalUrl?: string;
  schema?: object | object[];
  noExitIntent?: boolean;
  robots?: string;
  pageType?: string;
  dateModified?: string;
  isServicePage?: boolean;
}

const {
  title,
  description = 'Holy Webs helps service businesses get found online with web design, SEO, and local marketing.',
  ogImage = DEFAULT_OG_IMAGE,
  canonicalUrl = Astro.url.href,
  schema,
  noExitIntent = false,
  robots,
  pageType = 'WebPage',
  dateModified,
  isServicePage = false,
} = Astro.props;

const canonical = cleanCanonical(canonicalUrl);
const canonicalPath = new URL(canonical).pathname;
const absoluteOgImage = absoluteUrl(ogImage);
const pageRobots = getRobotsForPath(canonicalPath, robots);
const extraSchema = Array.isArray(schema) ? schema : schema ? [schema] : [];
const structuredData = graphSchema([
  organizationSchema(),
  websiteSchema(),
  webpageSchema({
    canonicalUrl: canonical,
    title,
    description,
    ogImage,
    pageType,
    dateModified,
  }),
  breadcrumbSchema(canonical),
  isServicePage ? serviceSchema({ canonicalUrl: canonical, title, description }) : undefined,
  ...extraSchema,
]);
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="robots" content={pageRobots} />
    <meta name="author" content={SITE_NAME} />
    <meta name="theme-color" content="#0f172a" />
    <link rel="canonical" href={canonical} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={absoluteOgImage} />
    <meta property="og:image:alt" content={`${SITE_NAME} digital marketing for local service businesses`} />
    <meta property="og:url" content={canonical} />
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content={SITE_NAME} />
    <meta property="og:locale" content="en_US" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={absoluteOgImage} />
    <link rel="icon" type="image/png" href="/favicon.png" />
    <link rel="sitemap" type="application/xml" href="/sitemap.xml" />
    <script type="application/ld+json" set:html={JSON.stringify(structuredData)} />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <!-- Non-render-blocking font load: page paints first, fonts swap in -->
    <link rel="preload" as="style" href="https://fonts.googleapis.com/css2?family=Inter:wght@400;600;700;800&family=Plus+Jakarta+Sans:wght@400;600;700;800&display=swap" />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;600;700;800&family=Plus+Jakarta+Sans:wght@400;600;700;800&display=swap" rel="stylesheet" media="print" onload="this.media='all'" />
    <noscript><link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;600;700;800&family=Plus+Jakarta+Sans:wght@400;600;700;800&display=swap" rel="stylesheet" /></noscript>
  </head>
  <body>
    <div class="min-h-screen flex flex-col">
      <Navbar client:load />
      <main class="flex-1 pt-28">
        <slot />
      </main>
      <Footer client:visible />
      {!noExitIntent && <ExitIntentPopup client:idle />}
    </div>
  </body>
</html>
