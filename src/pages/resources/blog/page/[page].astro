---
import Layout from '../../../../layouts/Layout.astro';
import Blog from '../../../../components/pages/Blog';

export function getStaticPaths() {
  // 8 posts at 6 per page = 2 pages total
  return [
    { params: { page: '2' } },
  ];
}

const { page } = Astro.params;
---

<Layout
  title={`Blog – Page ${page} | Holy Webs`}
  description="Practical marketing tips, SEO guides, and local business growth advice for contractors and service businesses."
  canonicalUrl={`https://holywebs.com/resources/blog/page/${page}`}
>
  <Blog client:idle />
</Layout>
