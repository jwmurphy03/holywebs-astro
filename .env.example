# Supabase — get these from your project's API settings at supabase.com
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=your-anon-key

# Stripe — publishable key from Stripe dashboard (Developers > API keys)
VITE_PAYMENTS_CLIENT_TOKEN=pk_live_...

# These go in Supabase Edge Function secrets (not .env), set via:
# supabase secrets set STRIPE_SECRET_KEY=sk_live_...
# supabase secrets set STRIPE_PRICE_BOOK_MAIN=price_...
# supabase secrets set STRIPE_PRICE_ACTION_PLAN_BUMP=price_...
